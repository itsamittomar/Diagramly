GROQ_API_KEY=your_groq_api_key
QDRANT_URL=https://your-cluster-id.europe-west3-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key

# Google OAuth SSO
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
JWT_SECRET=a_long_random_secret_string_at_least_32_chars

# Base URL of the app (used for OAuth callback redirect)
APP_URL=http://localhost:8080

# Access control (optional — leave both unset to allow any Google account)
# Restrict by domain:  only @yourcompany.com accounts
ALLOWED_DOMAIN=yourcompany.com
# Restrict by email:   comma-separated list of specific emails
# ALLOWED_EMAILS=alice@gmail.com,bob@gmail.com
